# Database
DATABASE_URL=postgresql+asyncpg://claywords:claywords_secret@localhost:5432/claywords
POSTGRES_USER=claywords
POSTGRES_PASSWORD=claywords_secret
POSTGRES_DB=claywords

# Redis
REDIS_URL=redis://localhost:6379

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=claywords
MINIO_SECRET_KEY=claywords_secret
MINIO_BUCKET=claywords
MINIO_SECURE=false
MINIO_ROOT_USER=claywords
MINIO_ROOT_PASSWORD=claywords_secret

# Crypto
CRYPTO_PEPPER=change_this_pepper_in_production

# JWT
JWT_SECRET_KEY=change_this_secret_key_in_production

# LLM Providers
LLM_PROVIDER=tongyi
TONGYI_API_KEY=your_tongyi_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
