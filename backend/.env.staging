# Staging Environment Configuration
# Phase Q10 P0: Staging 环境配置

# 环境标识
ENVIRONMENT=staging
DEBUG=True

# 版本
VERSION=1.0.0-staging

# CORS 配置（Staging 域名）
CORS_ORIGINS=https://staging.claywords.com,https://staging-api.claywords.com

# Database
DATABASE_URL=postgresql+asyncpg://claywords:{DATABASE_PASSWORD}@postgres-staging:5432/claywords_staging

# Redis
REDIS_URL=redis://redis-staging:6379

# MinIO
MINIO_ENDPOINT=minio-staging:9000
MINIO_ACCESS_KEY=claywords
MINIO_SECRET_KEY={MINIO_SECRET_KEY}
MINIO_BUCKET=claywords-staging
MINIO_SECURE=true

# Crypto
CRYPTO_PEPPER={CRYPTO_PEPPER}

# JWT
JWT_SECRET_KEY={JWT_SECRET_KEY}
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# LLM
LLM_PROVIDER=tongyi
TONGYI_API_KEY={TONGYI_API_KEY}

# Alipay (Sandbox)
ALIPAY_APP_ID=2021000000000000
ALIPAY_PRIVATE_KEY={ALIPAY_PRIVATE_KEY}
ALIPAY_PUBLIC_KEY={ALIPAY_PUBLIC_KEY}
ALIPAY_NOTIFY_URL=https://staging-api.claywords.com/api/v1/payments/callback
ALIPAY_RETURN_URL=https://staging.claywords.com/orders
