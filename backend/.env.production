# Production Environment Configuration
# Phase Q10 P0: 生产环境配置

# 环境标识
ENVIRONMENT=production
DEBUG=False

# 版本
VERSION=1.0.0

# CORS 配置（生产域名）
CORS_ORIGINS=https://claywords.com,https://www.claywords.com,https://api.claywords.com

# Database
DATABASE_URL=postgresql+asyncpg://claywords:${DATABASE_PASSWORD}@postgres-service:5432/claywords

# Redis
REDIS_URL=redis://redis-service:6379

# MinIO
MINIO_ENDPOINT=minio-service:9000
MINIO_ACCESS_KEY=claywords
MINIO_SECRET_KEY=${MINIO_SECRET_KEY}
MINIO_BUCKET=claywords
MINIO_SECURE=true

# Crypto (生产环境必须更改)
CRYPTO_PEPPER=${CRYPTO_PEPPER}

# JWT (生产环境必须更改)
JWT_SECRET_KEY=${JWT_SECRET_KEY}
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 天
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30  # 30 天

# LLM
LLM_PROVIDER=tongyi
TONGYI_API_KEY=${TONGYI_API_KEY}

# Alipay (生产配置)
ALIPAY_APP_ID=${ALIPAY_APP_ID}
ALIPAY_PRIVATE_KEY=${ALIPAY_PRIVATE_KEY}
ALIPAY_PUBLIC_KEY=${ALIPAY_PUBLIC_KEY}
ALIPAY_NOTIFY_URL=https://api.claywords.com/api/v1/payments/callback
ALIPAY_RETURN_URL=https://claywords.com/orders
